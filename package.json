{
  "name": "trip-manager",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,go,md}\"",
    "gen": "pnpm gen:go && pnpm gen:ts",
    
    "gen:ts": "mkdirp ./frontend/generated && openapi-merge-cli --config merge-config.json && openapi-typescript ./api-spec/merged/openapi.yaml -o ./frontend/generated/types.ts",
    "gen:go:users": "mkdirp ./backend/users/generated && oapi-codegen --config=oapi-codegen-users.yaml ./api-spec/users/openapi.yaml",
    "gen:go:trips": "mkdirp ./backend/trips/generated && oapi-codegen --config=oapi-codegen-trips.yaml ./api-spec/trips/openapi.yaml",
    "gen:go": "pnpm gen:go:users && pnpm gen:go:trips",
    "merge-schemas": "openapi-merge-cli --config merge-config.json",

    "clean": "rm -rf ./backend/internal/generated/*.go ./frontend/generated/{src,docs,.openapi-generator} ./frontend/generated/{*.json,*.md}",
    "clean:turbo": "rm -rf .turbo frontend/.turbo backend/.turbo"
  },
  "devDependencies": {
    "mkdirp": "^3.0.1",
    "openapi-merge-cli": "^1.3.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "latest",
    "turbo": "^2.8.21"
  },
  "packageManager": "pnpm@9.0.0"
}
