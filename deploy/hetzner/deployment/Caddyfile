# Caddyfile - Reverse Proxy Configuration

# Production Environment
$DOMAIN {
    # Logging
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
        }
    }

    # API Reverse Proxy
    handle /api/* {
        reverse_proxy backend:8000
    }

    # MinIO Reverse Proxy for Presigned URLs
    # Frontend needs to upload directly to MinIO via presigned URLs
    # IMPORTANT: Do NOT override the Host header - presigned URLs are signed with the original host
    handle /minio/* {
        uri strip_prefix /minio
        reverse_proxy minio:9000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Frontend Reverse Proxy
    handle {
        reverse_proxy frontend:3000
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    encode {
        gzip
        zstd
    }
}

