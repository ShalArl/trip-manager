# Trip Manager Environment Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# GitHub Container Registry (GHCR) - for Docker image authentication
# ============================================================================
# Your GitHub username (lowercase!)
GHCR_USERNAME=your-github-username

# Personal Access Token with 'read:packages' permission
# Generate at: https://github.com/settings/tokens
GHCR_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL username
DB_USER=trip_user

# PostgreSQL password (use strong password in production!)
DB_PASSWORD=SecurePassword123!@#

# Database name
DB_NAME=trip_manager

# ============================================================================
# Backend Configuration
# ============================================================================
# JWT Secret for token signing (change in production!)
# Generate: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production-$(openssl rand -base64 32)

# ============================================================================
# Frontend Configuration
# ============================================================================
# API URL for frontend requests
# Development: http://localhost:8000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# Server Configuration (Hetzner/Production)
# ============================================================================
# Domain for your application (used by Caddy reverse proxy)
# Examples: example.com, api.example.com, trip-manager.duck.dns
DOMAIN=trip-manager.duck.dns

# SSH Server Configuration
SERVER_HOST=192.168.1.100
SERVER_USER=deploy
SERVER_PORT=22

# SSH Private Key for server deployment (for manual deployments)
# Base64 encoded or path to key file
# HETZNER_DEPLOY_KEY=-----BEGIN OPENSSH PRIVATE KEY-----

# ============================================================================
# Application Environment
# ============================================================================
# Options: development, production, staging
ENVIRONMENT=development