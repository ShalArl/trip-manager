{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "bin/**"],
      "inputs": ["src/**", "app/**", "main.go", "go.mod", "go.sum", "api-spec/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "app/**", "test/**", "*.go"]
    },
    "gen": {
      "description": "Generate API client/server code from OpenAPI spec",
      "inputs": ["api-spec/openapi.yaml"],
      "outputs": ["backend/internal/api/generated.go", "frontend/src/generated/**"],
      "cache": false
    }
  }
}