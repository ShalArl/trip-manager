# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# GitHub Container Registry
# Your GitHub username
GHCR_USERNAME=octocat

# Personal Access Token with 'read:packages' scope
# Generate at: https://github.com/settings/tokens
GHCR_PAT=ghp_1234567890abcdefghijklmnopqrstuvwxyz

# Database Configuration
DB_USER=trip_user
DB_PASSWORD=SuperSecurePassword123!@#
DB_NAME=trip_manager

# Application Secrets
# Generate a random string for JWT signing: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Domain Configuration
# Your Duck DNS subdomain (without .duck.dns)
DOMAIN=mytrips.duck.dns

# Optional: API URL for Frontend (can be left empty for default)
NEXT_PUBLIC_API_URL=https://mytrips.duck.dns/api

# Optional: Server Configuration
SERVER_PORT=8000
ENVIRONMENT=production

# S3 Storage Configuration
# ─────────────────────────────────────────────────────────────
# IMPORTANT: Presigned URL Support
# For presigned URLs to work, S3_PUBLIC_URL must be publicly accessible
# ⚠️  S3_PUBLIC_URL should NOT include the bucket name!
# ─────────────────────────────────────────────────────────────

# For development (MinIO - local):
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=trip-manager
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000
S3_USE_SSL=false

# For development (MinIO - with Caddy reverse proxy):
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=trip-manager
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PUBLIC_URL=http://localhost/minio
# S3_USE_SSL=false

# For production (MinIO - expose via Caddy with HTTPS):
# ⚠️  IMPORTANT: Do NOT include bucket name in S3_PUBLIC_URL!
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=trip-manager
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PUBLIC_URL=https://travel-nugget.duckdns.org/minio
# S3_USE_SSL=false

# For production (AWS S3):
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=your-production-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key
# S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
# S3_USE_SSL=true

# Database URL (usually auto-generated, only set if needed)
# DATABASE_URL=postgresql://trip_user:password@database:5432/trip_manager
