# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# GitHub Container Registry
# Your GitHub username
GHCR_USERNAME=octocat

# Personal Access Token with 'read:packages' scope
# Generate at: https://github.com/settings/tokens
GHCR_PAT=ghp_1234567890abcdefghijklmnopqrstuvwxyz

# Database Configuration
DB_USER=trip_user
DB_PASSWORD=SuperSecurePassword123!@#
DB_NAME=trip_manager

# Application Secrets
# Generate a random string for JWT signing: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Domain Configuration
# Your Duck DNS subdomain (without .duck.dns)
DOMAIN=mytrips.duck.dns

# Optional: API URL for Frontend (can be left empty for default)
NEXT_PUBLIC_API_URL=https://mytrips.duck.dns/api

# Optional: Server Configuration
SERVER_PORT=8000
ENVIRONMENT=production

# Database URL (usually auto-generated, only set if needed)
# DATABASE_URL=postgresql://trip_user:password@database:5432/trip_manager

