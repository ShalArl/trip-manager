# Trip Manager Environment Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# Docker Registry (for production deployments)
# ============================================================================
GHCR_USERNAME=yourusername

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=trip_user
DB_PASSWORD=your_secure_password_here
DB_NAME=trip_manager

# ============================================================================
# Server Configuration
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here
DOMAIN=yoursubdomain.duck.dns

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
# ============================================================================
SERVER_PORT=8080

# ============================================================================
# Application Environment
# ============================================================================
# Options: development, production, testing
ENVIRONMENT=development

# ============================================================================
# JWT Secret for token signing
# ============================================================================
# IMPORTANT: Change this in production! Use a strong random string
# Example: $(openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-in-production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trip_manager

