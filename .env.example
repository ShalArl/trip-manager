# Trip Manager Environment Configuration
# Copy this file to .env and customize as needed

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trip_manager

# Server Configuration
SERVER_PORT=8080

# Application Environment
# Options: development, production, testing
ENVIRONMENT=development

# JWT Secret for token signing
# IMPORTANT: Change this in production! Use a strong random string
# Example: $(openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-in-production

# Optional: For Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trip_manager

